# noCRM — Clé API (Admin Panel > Integrations > API > API Keys)
NOCRM_API_KEY=""

# noCRM — Sous-domaine (ex: si ton URL est https://moncompte.nocrm.io → moncompte)
NOCRM_SUBDOMAIN=""

# OpenAI — Clé API (https://platform.openai.com/api-keys)
OPENAI_API_KEY="sk-xxxxxx"

# Alternatives : gpt-4o, gpt-4-turbo
OPENAI_MODEL="gpt-4o-mini"
